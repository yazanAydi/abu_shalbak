# ── Dependencies ────────────────────────────────────────
node_modules/

# ── Secrets / environment ───────────────────────────────
# Never commit real .env files (JWT secret, Telegram tokens, etc.)
.env
.env.*
!.env.example
!.env.store.example
!.env.development.example

# ── SQLite database — the shop's live data, NEVER commit ─
*.db
*.db-wal
*.db-shm
/data/*
!/data/.gitkeep
!/data/statements/
!/data/statements/suppliers/
!/data/statements/suppliers/.gitkeep
/data/statements/suppliers/*.pdf
/backend/data/statements/suppliers/*.pdf
/backend/data/
/backups/
/backend/backups/

# ── Build output (regenerated by npm run build) ─────────
/frontend/build/
/frontend-pos/build/
/backend/public/admin/
/backend/public/pos/

# ── Logs ────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS / editor junk ────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
