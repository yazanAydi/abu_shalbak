# Copy to frontend/.env on YOUR DEV PC.

PORT=3001

HOST=0.0.0.0

# Do NOT set REACT_APP_API_BASE — setupProxy.js forwards /api → backend :5001

# (works from PC, Tailscale IP, and Tailscale HTTPS on phone)

REACT_APP_POS_URL=http://127.0.0.1:3002

# Must match KIOSK_API_KEY in .env.development for /admin/kiosk

REACT_APP_KIOSK_API_KEY=dev-kiosk-key-change-in-store

# Ramallah shop calendar (must match backend TZ)
REACT_APP_SHOP_TZ=Asia/Hebron

