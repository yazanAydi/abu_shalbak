# Copy to .env.store on the SHOP SERVER PC only.
# Start store: npm run store:up

NODE_ENV=production
PORT=3000
HOST=0.0.0.0

JWT_SECRET=generate-a-long-random-string-32-chars-minimum
JWT_EXPIRES_IN=8h

DATABASE_PATH=/app/data/supermarket.db
BACKUP_DIR=/app/backups

TELEGRAM_USE_POLLING=1
TELEGRAM_REFUND_BOT_TOKEN=
TELEGRAM_REFUND_WEBHOOK_SECRET=
TELEGRAM_EXPIRY_BOT_TOKEN=
TELEGRAM_REFUND_CHAT_ID=
TELEGRAM_EXPIRY_CHAT_ID=
TELEGRAM_MANAGER_CHAT_ID=
TELEGRAM_EXPIRY_ALERT_HOUR=8
TELEGRAM_EXPIRY_DAYS=7
