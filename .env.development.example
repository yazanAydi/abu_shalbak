# Copy to .env.development on YOUR DEV PC.

# Start dev from repo root: npm start

#

# Isolated from the live store: separate DB, no Telegram bots, API on 5001.



NODE_ENV=development

PORT=5001

HOST=0.0.0.0

# Ramallah / Palestine local time for calendar-day boundaries
TZ=Asia/Hebron



# CORS for admin/POS dev servers (add your Tailscale IP if testing from phone)

ALLOWED_ORIGINS=http://127.0.0.1:3001,http://127.0.0.1:3002,http://localhost:3001,http://localhost:3002



# Optional — Tailscale HTTPS on phone (also auto-allowed in dev for *.ts.net):
# ALLOWED_ORIGINS=...,https://YOUR-PC.tailXXXX.ts.net



JWT_SECRET=dev-only-jwt-secret-not-for-production-use

JWT_EXPIRES_IN=8h



DATABASE_PATH=./data/supermarket-dev.db

BACKUP_DIR=./backups



# Keep Telegram empty in dev — store Docker owns the bots

TELEGRAM_USE_POLLING=0

TELEGRAM_REFUND_BOT_TOKEN=

TELEGRAM_REFUND_WEBHOOK_SECRET=

TELEGRAM_EXPIRY_BOT_TOKEN=

TELEGRAM_REFUND_CHAT_ID=

TELEGRAM_EXPIRY_CHAT_ID=

TELEGRAM_ZIMMA_BOT_TOKEN=

TELEGRAM_ZIMMA_CHAT_ID=

TELEGRAM_ZIMMA_WEBHOOK_SECRET=

TELEGRAM_SULAF_BOT_TOKEN=

TELEGRAM_SULAF_CHAT_ID=

TELEGRAM_SULAF_WEBHOOK_SECRET=

TELEGRAM_MANAGER_CHAT_ID=

TELEGRAM_EXPIRY_ALERT_HOUR=8

TELEGRAM_EXPIRY_DAYS=7



# Face attendance kiosk (dev/testing) — must match REACT_APP_KIOSK_API_KEY in frontend/.env

KIOSK_API_KEY=dev-kiosk-key-change-in-store



# Optional: copy store data once for realistic testing (read-only snapshot):

#   Copy-Item backend\data\supermarket.db backend\data\supermarket-dev.db

#

# Also copy frontend/.env.example → frontend/.env

# and frontend-pos/.env.example → frontend-pos/.env


